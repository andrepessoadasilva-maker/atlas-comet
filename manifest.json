{
  "manifest_version": 3,
  "name": "Atlas Comet",
  "version": "1.2.181",
  "description": "Atlas Comet: Tickets na rota certa. Automação e precisão para a tabulação de tickets no Freshdesk.",
  "permissions": [
    "webNavigation",
    "storage",
    "scripting"
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "host_permissions": [
    "https://*.freshdesk.com/*",
    "https://*.myfreshworks.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.freshdesk.com/*",
        "https://*.myfreshworks.com/*"
      ],
      "all_frames": true,
      "js": [
        "dist/content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "bridge-inject.js",
        "assets/icons/icon48.png",
        "assets/icons/cometa.gif"
      ],
      "matches": [
        "https://*.freshdesk.com/*"
      ]
    }
  ]
}
